# ─── Database ─────────────────────────────────────────────────────────────────
# Neon (Vercel) or Railway Postgres connection string
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=your_secret_here
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ─── RunPod ───────────────────────────────────────────────────────────────────
# One API key; two endpoint IDs
RUNPOD_API_KEY=your_runpod_api_key

# LLM endpoint — vLLM with Llama 3.1 8B (or 70B)
RUNPOD_LLM_ENDPOINT_ID=your_llm_endpoint_id
RUNPOD_LLM_MODEL=meta-llama/Llama-3.1-8B-Instruct

# TTS endpoint — Chatterbox worker
RUNPOD_TTS_ENDPOINT_ID=your_tts_endpoint_id

# ─── STT ──────────────────────────────────────────────────────────────────────
# Deepgram — Member role required for token grants
DEEPGRAM_API_KEY=your_deepgram_key

# ─── Memory / RAG ─────────────────────────────────────────────────────────────
# Pinecone — free starter tier
PINECONE_API_KEY=your_pinecone_key

# ─── Avatar ───────────────────────────────────────────────────────────────────
# Avaturn project subdomain (yourproject.avaturn.dev)
NEXT_PUBLIC_AVATURN_PROJECT=yourproject
