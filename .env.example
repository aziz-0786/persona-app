# ─── Database ─────────────────────────────────────────────────────────────────
# Neon (Vercel) or Railway Postgres connection string
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=your_secret_here
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ─── RunPod ───────────────────────────────────────────────────────────────────
# Used by /api/tts (Chatterbox voice cloning). No longer used for the LLM —
# /api/chat now calls Groq instead (see below).
RUNPOD_API_KEY=your_runpod_api_key

# LLM endpoint — unused since the Groq migration. Kept commented out, not
# deleted, in case Phase 7 scaling brings self-hosted vLLM back.
# RUNPOD_LLM_ENDPOINT_ID=your_llm_endpoint_id
# RUNPOD_LLM_MODEL=meta-llama/Llama-3.1-8B-Instruct

# TTS endpoint — Chatterbox worker
RUNPOD_TTS_ENDPOINT_ID=your_tts_endpoint_id

# ─── Groq ─────────────────────────────────────────────────────────────────────
# LLM for /api/chat. Get a key at console.groq.com.
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.1-8b-instant

# LLM: set true to use hardcoded stub responses for /api/chat (cost control,
# or when GROQ_API_KEY isn't configured yet). Set false to use the real
# Groq model. NOTE: does not affect /api/tts — TTS always calls RunPod
# regardless of this value; gate cost there via the TTS endpoint's own
# max_workers.
RUNPOD_OFFLINE=false

# ─── STT ──────────────────────────────────────────────────────────────────────
# Deepgram — Member role required for token grants
DEEPGRAM_API_KEY=your_deepgram_key

# ─── Memory / RAG ─────────────────────────────────────────────────────────────
# Pinecone — free starter tier
PINECONE_API_KEY=your_pinecone_key

# ─── Avatar ───────────────────────────────────────────────────────────────────
# Avaturn project subdomain (yourproject.avaturn.dev)
NEXT_PUBLIC_AVATURN_PROJECT=yourproject
